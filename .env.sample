MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASS=
MYSQL_DB=

PORT=

# Node runtime flags (optional)
# Docker dev default is to silence warnings: --no-warnings
NODE_OPTIONS=--no-warnings

# Logger (Nest)
# error | warn | log | debug | verbose
LOG_LEVEL=log

JWT_SECRET=
JWT_EXPIRES_IN=

# Admin bootstrap (used by: npm run seed:admin)
ADMIN_NAME=Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourapp.com

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379


